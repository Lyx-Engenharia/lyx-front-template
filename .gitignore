# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-fixtures

# audit artifacts (eslint.json, depcruise.json, report.md gerados pelo CI)
/audit

# next.js
.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test

# vercel
.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts

# turborepo
.turbo/

# git worktrees
/.worktrees
